# Database
DATABASE_URL=postgresql://mrtrader:mrtrader_password@localhost:5432/mrtrader

# Redis
REDIS_URL=redis://localhost:6379

# Alpaca API
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets  # Change to https://api.alpaca.markets for live trading

# NewsAPI
NEWS_API_KEY=your_newsapi_key

# Trading Configuration
TRADING_MODE=paper  # 'paper' or 'live'
INITIAL_CAPITAL=20000
MAX_POSITION_SIZE_PCT=0.05  # 5% of account
MAX_SECTOR_CONCENTRATION_PCT=0.20  # 20% of account
MAX_DAILY_LOSS_PCT=0.02  # 2% of account
MAX_ACCOUNT_DRAWDOWN_PCT=0.05  # 5% of account

# Alerts — Slack
SLACK_WEBHOOK_URL=your_slack_webhook_url

# Alerts — Email (SMTP)
# Gmail: use an App Password (not your login password)
# https://myaccount.google.com/apppasswords
ALERT_EMAIL=your_email@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_sender@gmail.com
SMTP_PASSWORD=your_app_password_here

# Application
LOG_LEVEL=INFO
DEBUG=False
PORT=8000

# ML Model
MODEL_RETRAINING_HOUR=17  # 5 PM (after market close)
HISTORICAL_DATA_YEARS=3

# Market
MARKET_OPEN_TIME=09:30
MARKET_CLOSE_TIME=16:00
TRADER_CHECK_INTERVAL=300  # 5 minutes in seconds
